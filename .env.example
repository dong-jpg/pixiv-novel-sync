# Pixiv 凭据 - 至少配置 PIXIV_REFRESH_TOKEN，或同时配置 PIXIV_USERNAME / PIXIV_PASSWORD（用于 Playwright 自动获取 token）
PIXIV_REFRESH_TOKEN=
PIXIV_ACCESS_TOKEN=
PIXIV_USER_ID=
PIXIV_USERNAME=
PIXIV_PASSWORD=

# 网络
PIXIV_PROXY=
PIXIV_TIMEOUT=30
PIXIV_VERIFY_SSL=true

# Web Cookie 用于读取追更系列列表（Pixiv 网页版登录后从浏览器复制）
PIXIV_WEB_COOKIE=

# 存储路径
PIXIV_PUBLIC_DIR=./data/library/public
PIXIV_PRIVATE_DIR=./data/library/private
PIXIV_DB_PATH=./data/state/pixiv_sync.db
PIXIV_LOG_LEVEL=INFO

# Dashboard 访问密码（公网/反代部署必须配置；留空时仅允许本机访问）
DASHBOARD_TOKEN=

# 是否信任反向代理注入的 X-Forwarded-For（仅在确实部署于可信反代之后才开启）
DASHBOARD_TRUST_PROXY=false
# 可信反代层数：真实客户端 IP 位于 X-Forwarded-For 右数第 N 个条目，默认 1（单层 nginx）。
# 用于抵御伪造 XFF 绕过登录限流 / 本机判定。
DASHBOARD_TRUSTED_PROXY_HOPS=1

# Flask session 密钥（缺省时服务会生成随机值并写回 .env；生产建议手动固定）
PIXIV_FLASK_SECRET=

# 反代场景启用 HTTPS 时设为 true，让 session cookie 仅经 HTTPS 传输。
# 留空时：检测到反代头会自动开启（可用 PIXIV_COOKIE_SECURE=false 强制关闭，仅纯 HTTP 本机调试用）。
PIXIV_COOKIE_SECURE=

# OAuth 回调外部地址（反代部署建议显式配置，如 https://novel.example.com），
# 避免依赖客户端可控的 Host 头构造回调 URL 被投毒劫持。
PIXIV_EXTERNAL_BASE_URL=

# AI 创作工作台 API key 加密密钥（保存 AI Provider API key 前必须配置，并保持稳定）
PIXIV_NOVEL_SYNC_AI_SECRET_KEY=

# AI Provider base_url 安全校验：默认拒绝指向本机/内网/云元数据地址（防 SSRF/密钥外泄）。
# 如需访问本机或内网自建模型服务，设为 1 放行私有/回环地址（仍禁止 link-local 元数据）。
PIXIV_AI_ALLOW_PRIVATE_HOSTS=
